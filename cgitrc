#
# cgit config
#

# Globals
css=/cgit.css
logo=/cgit.png

branch-sort=age
enable-blame=1
commit-sort=topo
#enable-commit-graph=1
enable-index-owner=0
enable-subject-links=1
#footer=/repos/footer.html
#head-include=/repos/head-include.html
#header=/repos/header.html
max-repo-count=0
max-stats=year
# Remove trailing .git from urls and names
remove-suffix=1
repository-sort=age
robots=noindex, nofollow
root-desc=Open source repositories
#root-readme=/repos/root-readme.html
root-title=Christopher Fujino
side-by-side-diffs=1

# Scan a directory
scan-path=/repos
